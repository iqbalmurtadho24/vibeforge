# Apache Configuration - Vibeforge
# ================================================
# Place this file in the project root (outside public/)

# This is a secondary security layer
# Main security is in public/.htaccess

# Disable directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(env|log|sql|md|json|key|pem)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to backup files
<FilesMatch "\.(bak|backup|old|orig|original|swp|swo)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to version control
<FilesMatch "^\.(git|svn|hg|gitignore|gitattributes)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to IDE files
<FilesMatch "^\.(idea|vscode|vs|settings)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block direct access to important directories
# Note: core/ is allowed for the router proxy to function
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(include|modules|data|cache|migrations|docs)/ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
</IfModule>

# open_basedir hardening.
# NOTE: this path is environment-specific and MUST match the deploy location.
# The hardcoded Windows/Laragon path below breaks on a Linux production host,
# so it is disabled by default. Re-enable and set the correct absolute path
# for the target server before/at deploy (e.g. /home/USER/public_html).
# <IfModule mod_php.c>
#     php_admin_value open_basedir "D:/laragon/www/[nama-app]:/tmp"
# </IfModule>
