# =============================================================================
# Environment Configuration Template
# =============================================================================
# Clone file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke version control!
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================

# Nama display untuk UI
APP_DISPLAY_NAME="MyApp"

# Tagline aplikasi
APP_TAGLINE="Your app tagline here"

# Environment: development | staging | production
APP_ENV="development"

# Debug mode: true | false
# Debug=true hanya untuk development! Di production SELALU false
APP_DEBUG="true"

# Application key (generate dengan: openssl rand -hex 32)
APP_KEY=""

# =============================================================================
# DATABASE
# =============================================================================

# Database mode: auto | json | mysql
# auto  = default. Deteksi otomatis per tabel: pakai MySQL kalau koneksi
#         hidup DAN tabelnya ada, kalau tidak fallback ke data/*.json
# json  = paksa selalu JSON, abaikan koneksi MySQL (demo/testing terisolasi)
# mysql = paksa selalu MySQL, HALT (bukan fallback diam-diam) kalau
#         koneksi/tabel tidak tersedia (lihat CLAUDE.md Section 3g)
DB_MODE="auto"

# MySQL Configuration (jika DB_MODE=mysql)
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="myapp_db"
DB_USER="root"
DB_PASSWORD=""

# =============================================================================
# SECURITY
# =============================================================================

# CSRF Token Key (generate dengan: openssl rand -hex 32)
CSRF_KEY=""

# Session lifetime dalam detik (default: 7200 = 2 jam)
SESSION_LIFETIME="7200"

# Remember-me secret (generate dengan: openssl rand -hex 64)
REMEMBER_ME_SECRET=""

# Rate limiting: jumlah max request per window
RATE_LIMIT_MAX_ATTEMPTS="5"
RATE_LIMIT_WINDOW="300"

# =============================================================================
# FILE UPLOADS
# =============================================================================

# Max upload size in bytes (default: 50MB)
UPLOAD_MAX_SIZE="52428800"

# Allowed MIME types (comma-separated)
UPLOAD_ALLOWED_TYPES="audio/mpeg,audio/wav,audio/mp3"

# =============================================================================
# LOGGING
# =============================================================================

# Path untuk debug log
LOG_PATH="cache/debug.log"

# Audit trail path
AUDIT_TRAIL_PATH="data/audit_trail.json"

# =============================================================================
# OPTIONAL: OAuth / Third-party Integration
# =============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# =============================================================================
# OPTIONAL: Payment Gateway
# =============================================================================

# Midtrans
# MIDTRANS_SERVER_KEY=""
# MIDTRANS_CLIENT_KEY=""
# MIDTRANS_IS_PRODUCTION="false"

# =============================================================================
# OPTIONAL: Storage
# =============================================================================

# Storage mode: local | s3 | gcs
STORAGE_MODE="local"

# AWS S3 (jika STORAGE_MODE=s3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="ap-southeast-1"
# AWS_BUCKET=""
